{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Signer main window: file dialogs, PDF read/write anywhere the user points, signature store in app data, reveal in Explorer, OS locale.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "os:default",
    "os:allow-locale",
    "os:allow-platform",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }, { "path": "$APPDATA" }, { "path": "$APPDATA/**" }]
    }
  ]
}
