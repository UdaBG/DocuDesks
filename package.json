    "@fontsource/homemade-apple": "^5.2.5",
    "@fontsource/sacramento": "^5.2.5",
    "@fontsource/schibsted-grotesk": "^5.2.5",
    "@pdf-lib/fontkit": "^1.1.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "i18next": "^26.3.4",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "perfect-freehand": "^1.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "typescript": "^5.7.0",
    "vite": "^8.1.3",
    "zustand": "^5.0.14"
