    "dist:tauri": "tauri build",
    "typecheck": "tsc --noEmit",
    "build:renderer": "vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "build": "npm run typecheck && npm run build:renderer && npm run build:electron",
    "icon": "node scripts/make-icon.mjs",
    "samples": "node scripts/make-samples.mjs",
    "dist": "npm run build && npm run icon && electron-builder --win",
    "start": "electron ."
  },
  "devDependencies": {
